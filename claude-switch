#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# claude-switch — Run multiple Claude Code accounts on one machine
#                 With third-party API provider support. Pure bash.
# ─────────────────────────────────────────────────────────────────────────────

VERSION="2.4.0"
CLAUDE_HOME="$HOME/.claude"
PROFILE_PREFIX="$HOME/.claude-"
PROFILE_MARKER=".profile-name"
PROVIDER_CONFIG=".provider.json"
ZSHRC="$HOME/.bashrc"
SHARED_ITEMS="skills CLAUDE.md plugins projects"

# ── Colors & Icons ───────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

IC_CHECK="\xe2\x9c\x94"   # ✔
IC_CROSS="\xe2\x9c\x98"   # ✘
IC_ARROW="\xe2\x96\xb6"   # ▶
IC_PERSON="\xe2\x97\x89"  # ◉
IC_LINK="\xe2\x86\x92"    # →
IC_API="\xe2\x97\x86"     # ◆

# ── Print helpers ────────────────────────────────────────────────────────────

print_header() {
    echo ""
    printf "  ${BOLD}${YELLOW}╔═══════════════════════════════════════════════╗${RESET}\n"
    printf "  ${BOLD}${YELLOW}║${RESET}        ${BOLD}C L A U D E   S W I T C H${RESET}              ${BOLD}${YELLOW}║${RESET}\n"
    printf "  ${BOLD}${YELLOW}║${RESET}   ${DIM}v%-7s · multi-account + 3rd-party API${RESET}  ${BOLD}${YELLOW}║${RESET}\n" "$VERSION"
    printf "  ${BOLD}${YELLOW}╚═══════════════════════════════════════════════╝${RESET}\n"
    echo ""
}

print_success() { printf "  ${GREEN}${IC_CHECK}${RESET}  %s\n" "$1"; }
print_error()   { printf "  ${RED}${IC_CROSS}${RESET}  %s\n" "$1"; }
print_warn()    { printf "  ${YELLOW}!${RESET}  %s\n" "$1"; }
print_info()    { printf "  ${BLUE}${IC_ARROW}${RESET}  %s\n" "$1"; }
print_dim()     { printf "  ${DIM}   %s${RESET}\n" "$1"; }

# Print a simple section header (replaces gum's bordered callout).
print_section() {
    local title="$1" subtitle="${2:-}"
    echo ""
    printf "  ${BOLD}${CYAN}── %s ──${RESET}\n" "$title"
    [ -n "$subtitle" ] && printf "  ${DIM}%s${RESET}\n" "$subtitle"
    echo ""
}

# ── Interactive prompts (replaces gum input/confirm/choose) ──────────────────
# All UI goes to stderr; the answer is returned via the global $INPUT_RESULT
# so callers can safely use these inside $(…) captures.

# ask_input "Prompt" ["default"] → sets INPUT_RESULT
ask_input() {
    local prompt="$1" default="${2:-}"
    if [ -n "$default" ]; then
        read -r -p "  $(printf "${CYAN}?${RESET} %s [${DIM}%s${RESET}]: " "$prompt" "$default")" INPUT_RESULT
        [ -z "$INPUT_RESULT" ] && INPUT_RESULT="$default"
    else
        read -r -p "  $(printf "${CYAN}?${RESET} %s: " "$prompt")" INPUT_RESULT
    fi
}

# ask_password "Prompt" → sets INPUT_RESULT (input hidden)
ask_password() {
    local prompt="$1"
    read -rs -p "  $(printf "${CYAN}?${RESET} %s: " "$prompt")" INPUT_RESULT
    echo "" >&2
}

# ask_confirm "Prompt" ["Y"|"N" default] → exit 0 = yes, 1 = no
ask_confirm() {
    local prompt="$1" default="${2:-N}" reply
    local hint="[y/N]"
    [ "$default" = "Y" ] && hint="[Y/n]"
    read -r -p "  $(printf "${CYAN}?${RESET} %s ${DIM}%s${RESET}: " "$prompt" "$hint")" reply
    [ -z "$reply" ] && reply="$default"
    [[ "$reply" =~ ^[Yy] ]]
}

# ask_choose "Prompt" opt1 opt2 ... → sets INPUT_RESULT to chosen option
ask_choose() {
    local prompt="$1"; shift
    local options=("$@")
    {
        echo ""
        printf "  ${BOLD}%s${RESET}\n" "$prompt"
        local i
        for i in "${!options[@]}"; do
            printf "    ${YELLOW}%d)${RESET} %s\n" $((i+1)) "${options[$i]}"
        done
        echo ""
    } >&2
    local pick
    while true; do
        read -r -p "  $(printf "${CYAN}?${RESET} Choose [${DIM}1-%d${RESET}]: " "${#options[@]}")" pick
        if [[ "$pick" =~ ^[0-9]+$ ]] && [ "$pick" -ge 1 ] && [ "$pick" -le "${#options[@]}" ]; then
            INPUT_RESULT="${options[$((pick-1))]}"
            return 0
        fi
        printf "    ${RED}Invalid selection.${RESET}\n" >&2
    done
}

# ── Utility Functions ────────────────────────────────────────────────────────

validate_profile_name() {
    local name="$1"
    if [ -z "$name" ]; then
        print_error "Profile name cannot be empty."
        return 1
    fi
    if [ "$name" = "default" ]; then
        print_error "'default' is reserved for the primary ~/.claude/ profile."
        return 1
    fi
    if ! printf '%s' "$name" | grep -qE '^[a-zA-Z][a-zA-Z0-9_-]*$'; then
        print_error "Invalid name. Use letters, numbers, hyphens, underscores. Must start with a letter."
        return 1
    fi
    if [ ${#name} -gt 32 ]; then
        print_error "Profile name must be 32 characters or fewer."
        return 1
    fi
    return 0
}

profile_dir() { echo "${PROFILE_PREFIX}$1"; }

profile_exists() {
    local dir
    dir="$(profile_dir "$1")"
    [ -d "$dir" ] && [ -f "$dir/$PROFILE_MARKER" ]
}

is_api_profile() {
    local dir
    dir="$(profile_dir "$1")"
    [ -f "$dir/$PROVIDER_CONFIG" ]
}

get_all_profiles() {
    for dir in "${PROFILE_PREFIX}"*/; do
        [ -d "$dir" ] || continue
        [ -f "$dir/$PROFILE_MARKER" ] || continue
        local name
        name="$(basename "$dir")"
        name="${name#.claude-}"
        echo "$name"
    done
}

check_auth_status() {
    local config_dir="$1"
    local output
    if [ "$config_dir" = "$CLAUDE_HOME" ]; then
        output=$(claude auth status 2>&1) || true
    else
        output=$(CLAUDE_CONFIG_DIR="$config_dir" claude auth status 2>&1) || true
    fi
    local email
    email=$(printf '%s' "$output" | grep -o '"email"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"email"[[:space:]]*:[[:space:]]*"//;s/"//')
    if [ -n "$email" ]; then
        echo "$email"
    elif printf '%s' "$output" | grep -q '"loggedIn": true'; then
        echo "logged in"
    else
        echo ""
    fi
}

pick_profile() {
    local action="$1"
    local profiles
    profiles=$(get_all_profiles)
    if [ -z "$profiles" ]; then
        print_warn "No profiles found. Create one first." >&2
        return 1
    fi
    local options=()
    while IFS= read -r p; do options+=("$p"); done <<<"$profiles"
    ask_choose "Select a profile to ${action}:" "${options[@]}"
    printf '%s' "$INPUT_RESULT"
}

# ── Provider config helpers (pure bash JSON I/O) ─────────────────────────────
# .provider.json is a flat object with string values that we write ourselves,
# so a tiny escape/unescape pair is enough. Values must not contain literal
# control chars; quotes and backslashes are handled.

json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"   # \ → \\
    s="${s//\"/\\\"}"   # " → \"
    printf '%s' "$s"
}

read_provider_field() {
    local file="$1" field="$2"
    [ -f "$file" ] || { echo ""; return; }
    # Match: "field": "value"[,]   on its own line. Greedy capture handles
    # embedded \" since the trailing " is the LAST one on the line.
    local raw
    raw=$(sed -n "s/^[[:space:]]*\"${field}\"[[:space:]]*:[[:space:]]*\"\\(.*\\)\",\\{0,1\\}[[:space:]]*\$/\\1/p" "$file" | head -1)
    # Unescape — order matters: \" before \\ (otherwise \\" decodes wrong).
    raw="${raw//\\\"/\"}"
    raw="${raw//\\\\/\\}"
    printf '%s' "$raw"
}

write_provider_config() {
    local dir="$1" base_url="$2" auth_token_cmd="$3" model="$4"
    local haiku="${5:-$model}" sonnet="${6:-$model}" opus="${7:-$model}" subagent="${8:-$model}"
    {
        printf '{\n'
        printf '  "base_url": "%s",\n'       "$(json_escape "$base_url")"
        printf '  "auth_token_cmd": "%s",\n' "$(json_escape "$auth_token_cmd")"
        printf '  "model": "%s",\n'          "$(json_escape "$model")"
        printf '  "haiku_model": "%s",\n'    "$(json_escape "$haiku")"
        printf '  "sonnet_model": "%s",\n'   "$(json_escape "$sonnet")"
        printf '  "opus_model": "%s",\n'     "$(json_escape "$opus")"
        printf '  "subagent_model": "%s"\n'  "$(json_escape "$subagent")"
        printf '}\n'
    } > "$dir/$PROVIDER_CONFIG"
    chmod 600 "$dir/$PROVIDER_CONFIG" 2>/dev/null || true
}

# ── Secret storage backends ──────────────────────────────────────────────────
# The API key is NEVER written into .provider.json or your shell rc. It is handed
# to a secret manager, and .provider.json stores only "auth_token_cmd" — a command
# that prints the key back at launch time (same idea as git's credential.helper).
# Because it is just a shell command, you can hand-edit it to use ANY backend:
#   pass show …        op read …        vault kv get …        printf %s "$MY_ENV"

SECRET_SERVICE="claude-switch"   # namespace inside the secret manager

detect_secret_backends() {
    command -v pass        >/dev/null 2>&1 && echo "pass"
    command -v secret-tool >/dev/null 2>&1 && echo "secret-tool"
    [ "$(uname)" = "Darwin" ] && command -v security >/dev/null 2>&1 && echo "keychain"
    echo "plaintext"
}

# store_secret <backend> <name> <dir> <token>  → prints the auth_token_cmd to save
store_secret() {
    local backend="$1" name="$2" dir="$3" token="$4"
    case "$backend" in
        pass)
            printf '%s\n' "$token" | pass insert -m -f "${SECRET_SERVICE}/${name}" >/dev/null || return 1
            printf 'pass show %s/%s' "$SECRET_SERVICE" "$name" ;;
        secret-tool)
            printf '%s' "$token" | secret-tool store --label="${SECRET_SERVICE}: ${name}" \
                service "$SECRET_SERVICE" account "$name" || return 1
            printf 'secret-tool lookup service %s account %s' "$SECRET_SERVICE" "$name" ;;
        keychain)
            security add-generic-password -U -s "$SECRET_SERVICE" -a "$name" -w "$token" >/dev/null 2>&1 || return 1
            printf 'security find-generic-password -s %s -a %s -w' "$SECRET_SERVICE" "$name" ;;
        plaintext)
            local tf="$dir/.token"
            ( umask 077; printf '%s' "$token" > "$tf" ) || return 1
            print_warn "Key saved in cleartext at $tf (chmod 600) — a secret manager is safer." >&2
            printf 'cat %s' "$tf" ;;
        *) return 1 ;;
    esac
}

# resolve_auth_token <dir> → prints the live API key by running auth_token_cmd,
# falling back to a legacy inline "auth_token" from pre-2.4 config files.
resolve_auth_token() {
    local dir="$1" cfg="$dir/$PROVIDER_CONFIG" cmd
    cmd=$(read_provider_field "$cfg" "auth_token_cmd")
    if [ -n "$cmd" ]; then
        eval "$cmd"
    else
        read_provider_field "$cfg" "auth_token"   # legacy plaintext
    fi
}

# ── Commands ─────────────────────────────────────────────────────────────────

configure_third_party() {
    local dir="$1" name="$2"

    print_section "🔌 Third-Party API Configuration" \
        "Configure your API provider (DeepSeek, Volcano Engine, OpenRouter, etc.)"

    # Base URL
    local base_url
    ask_input "API Base URL"
    base_url="$INPUT_RESULT"
    if [ -z "$base_url" ]; then
        print_error "Base URL is required."
        return 1
    fi

    # API Key
    local auth_token
    ask_password "API Key / Auth Token"
    auth_token="$INPUT_RESULT"
    if [ -z "$auth_token" ]; then
        print_error "API key is required."
        return 1
    fi

    # Primary model
    local model
    ask_input "Primary Model Name (e.g. deepseek-v4-pro, glm-5.1, ark-code-latest)"
    model="$INPUT_RESULT"
    if [ -z "$model" ]; then
        print_error "Model name is required."
        return 1
    fi

    # Ask about per-tier models
    local haiku="$model" sonnet="$model" opus="$model" subagent="$model"

    echo ""
    if ask_confirm "Use different models for different tiers (Haiku/Sonnet/Opus)?"; then
        ask_input "Opus model (complex tasks)" "$model";   opus="$INPUT_RESULT"
        [ -z "$opus" ]    && opus="$model"
        ask_input "Sonnet model (balanced tasks)" "$model"; sonnet="$INPUT_RESULT"
        [ -z "$sonnet" ]  && sonnet="$model"
        ask_input "Haiku model (fast/light tasks)" "$model"; haiku="$INPUT_RESULT"
        [ -z "$haiku" ]   && haiku="$model"
        ask_input "Subagent model" "$haiku"; subagent="$INPUT_RESULT"
        [ -z "$subagent" ] && subagent="$haiku"
    fi

    # Hand the key to a secret manager; .provider.json keeps only a retrieval command.
    print_section "🔐 Where to keep the API key" \
        "claude-switch stores only a command that fetches it — never the key itself."
    local backends=(); while IFS= read -r b; do backends+=("$b"); done < <(detect_secret_backends)
    ask_choose "Secret storage backend:" "${backends[@]}"
    local backend="$INPUT_RESULT" auth_token_cmd
    auth_token_cmd=$(store_secret "$backend" "$name" "$dir" "$auth_token") || {
        print_error "Could not store the key via '$backend'."; return 1; }

    # Save provider config (retrieval command only, no plaintext key)
    write_provider_config "$dir" "$base_url" "$auth_token_cmd" "$model" "$haiku" "$sonnet" "$opus" "$subagent"

    # Create settings.json with model (don't symlink from shared)
    rm -f "$dir/settings.json" 2>/dev/null || true
    printf '{\n  "theme": "dark",\n  "model": "%s"\n}\n' "$model" > "$dir/settings.json"

    # Set hasCompletedOnboarding
    printf '{\n  "hasCompletedOnboarding": true\n}\n' > "$dir/.claude.json"

    echo ""
    printf "    ${DIM}${IC_API} Base URL:  %s${RESET}\n" "$base_url"
    printf "    ${DIM}${IC_API} Key store: %s${RESET}\n" "$backend"
    printf "    ${DIM}${IC_API} Retrieval: %s${RESET}\n" "$auth_token_cmd"
    printf "    ${DIM}${IC_API} Model:     %s${RESET}\n" "$model"
    if [ "$haiku" != "$model" ] || [ "$sonnet" != "$model" ] || [ "$opus" != "$model" ]; then
        printf "    ${DIM}${IC_API} Opus:      %s${RESET}\n" "$opus"
        printf "    ${DIM}${IC_API} Sonnet:    %s${RESET}\n" "$sonnet"
        printf "    ${DIM}${IC_API} Haiku:     %s${RESET}\n" "$haiku"
        printf "    ${DIM}${IC_API} Subagent:  %s${RESET}\n" "$subagent"
    fi
    echo ""
    print_success "Third-party API configured"
}

cmd_create() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        ask_input "Profile name (e.g. work, deepseek, hs)"
        name="$INPUT_RESULT"
    fi

    if [ -z "$name" ]; then
        print_info "Cancelled."
        exit 0
    fi

    if ! validate_profile_name "$name"; then
        exit 1
    fi

    local dir
    dir="$(profile_dir "$name")"

    if [ -d "$dir" ] && [ -f "$dir/$PROFILE_MARKER" ]; then
        print_error "Profile '$name' already exists at $dir"
        exit 1
    fi

    if [ -d "$dir" ] && [ ! -f "$dir/$PROFILE_MARKER" ]; then
        print_error "Directory $dir exists but is not a profile."
        print_dim "Inspect it manually or choose a different name."
        exit 1
    fi

    # Ask about profile type
    ask_choose "What type of profile?" \
        "Anthropic (OAuth login)" \
        "Third-party API (DeepSeek, Volcano Engine, OpenRouter, etc.)"
    local profile_type="$INPUT_RESULT"

    local is_third_party=false
    case "$profile_type" in
        "Third-party"*) is_third_party=true ;;
    esac

    # Create profile
    printf "\n  ${BOLD}Creating profile '${CYAN}%s${RESET}${BOLD}'${RESET}\n\n" "$name"

    mkdir -p "$dir"
    echo "$name" > "$dir/$PROFILE_MARKER"

    # Symlink shared items (skip settings.json for third-party — they get their own)
    local items_to_link="$SHARED_ITEMS"
    if [ "$is_third_party" = false ]; then
        items_to_link="$SHARED_ITEMS settings.json"
    fi

    for item in $items_to_link; do
        if [ -e "$CLAUDE_HOME/$item" ]; then
            ln -sf "$CLAUDE_HOME/$item" "$dir/$item"
            printf "    ${DIM}${IC_LINK} %s${RESET}\n" "$item"
        else
            printf "    ${DIM}~ %s (not found, will link when created)${RESET}\n" "$item"
        fi
    done

    echo ""
    print_success "Profile created at ~/.claude-$name/"

    # Configure provider if selected
    if [ "$is_third_party" = true ]; then
        configure_third_party "$dir" "$name"
    fi

    echo ""

    # Add alias to shell rc
    if [ ! -f "$ZSHRC" ]; then
        touch "$ZSHRC"
    fi

    if grep -q "alias claude-${name}=" "$ZSHRC" 2>/dev/null; then
        # Remove old alias to replace it
        sed -i "/^# Claude profile: ${name}$/d" "$ZSHRC" 2>/dev/null || true
        sed -i "/^alias claude-${name}=/d" "$ZSHRC" 2>/dev/null || true
    fi

    # The alias just delegates to claude-switch, which resolves the key (and the
    # provider env) at launch. No secret — and no provider config — is ever
    # written into ~/.bashrc.
    printf "\n# Claude profile: %s\nalias claude-%s='claude-switch launch %s'\n" \
        "$name" "$name" "$name" >> "$ZSHRC"
    printf "  ${GREEN}${IC_CHECK}${RESET}  Added alias ${BOLD}claude-${name}${RESET} to ~/.bashrc\n"

    echo ""
    print_section "Quick start"
    if [ "$is_third_party" = true ]; then
        printf "    source ~/.bashrc\n"
        printf "    ${CYAN}claude-%s${RESET}\n\n" "$name"
        printf "    ${DIM}Third-party API configured — no OAuth login needed.${RESET}\n"
    else
        printf "    source ~/.bashrc\n"
        printf "    ${CYAN}claude-switch %s${RESET}\n\n" "$name"
        printf "    ${DIM}Claude will prompt you to log in on first launch.${RESET}\n"
    fi
    echo ""
}

cmd_list() {
    echo ""
    printf "  ${BOLD}Profiles${RESET}\n\n"

    # Default profile
    local default_status
    default_status=$(check_auth_status "$CLAUDE_HOME")

    if [ -n "$default_status" ]; then
        printf "  ${IC_PERSON}  ${BOLD}%-16s${RESET} ${DIM}%-24s${RESET} ${GREEN}${IC_CHECK} %s${RESET}\n" \
            "default" "~/.claude/" "$default_status"
    else
        printf "  ${IC_PERSON}  ${BOLD}%-16s${RESET} ${DIM}%-24s${RESET} ${RED}${IC_CROSS} not logged in${RESET}\n" \
            "default" "~/.claude/"
    fi

    # Additional profiles
    local profiles
    profiles=$(get_all_profiles)
    if [ -n "$profiles" ]; then
        while IFS= read -r name; do
            local dir status provider_label=""
            dir="$(profile_dir "$name")"

            # Check if third-party API profile
            if [ -f "$dir/$PROVIDER_CONFIG" ]; then
                local api_model
                api_model=$(read_provider_field "$dir/$PROVIDER_CONFIG" "model")
                provider_label="API: $api_model"
                printf "  ${IC_API}  ${BOLD}%-16s${RESET} ${DIM}%-24s${RESET} ${MAGENTA}${IC_CHECK} %s${RESET}\n" \
                    "$name" "~/.claude-$name/" "$provider_label"
            else
                status=$(check_auth_status "$dir")
                if [ -n "$status" ]; then
                    printf "  ${IC_PERSON}  ${BOLD}%-16s${RESET} ${DIM}%-24s${RESET} ${GREEN}${IC_CHECK} %s${RESET}\n" \
                        "$name" "~/.claude-$name/" "$status"
                else
                    printf "  ${IC_PERSON}  ${BOLD}%-16s${RESET} ${DIM}%-24s${RESET} ${RED}${IC_CROSS} not logged in${RESET}\n" \
                        "$name" "~/.claude-$name/"
                fi
            fi
        done <<< "$profiles"
    fi

    echo ""

    local count=1
    if [ -n "$profiles" ]; then
        local profile_count
        profile_count=$(printf '%s\n' "$profiles" | wc -l | tr -d ' ')
        count=$((profile_count + 1))
    fi
    printf "  ${DIM}%d profile(s) total${RESET}\n\n" "$count"
}

cmd_delete() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        name=$(pick_profile "delete") || exit 1
    fi

    if [ "$name" = "default" ]; then
        print_error "Cannot delete the default profile."
        exit 1
    fi

    if ! profile_exists "$name"; then
        print_error "Profile '$name' does not exist."
        exit 1
    fi

    local dir
    dir="$(profile_dir "$name")"

    local sec_hint=""
    [ -f "$dir/$PROVIDER_CONFIG" ] && sec_hint=$(read_provider_field "$dir/$PROVIDER_CONFIG" "auth_token_cmd")

    print_section "Delete profile '${name}'" \
        "Removes ~/.claude-${name}/, the alias from ~/.bashrc, and all sessions."
    print_dim "OAuth tokens in macOS Keychain may persist."
    echo ""

    if ! ask_confirm "Delete profile '${name}'?"; then
        echo ""
        print_info "Cancelled."
        echo ""
        return
    fi

    echo ""

    rm -rf "$dir"
    print_success "Removed ~/.claude-$name/"

    if [ -n "$sec_hint" ]; then
        print_info "The API key is still in your secret manager — remove it if unused:"
        print_dim "was fetched via:  $sec_hint"
    fi

    if [ -f "$ZSHRC" ]; then
        sed -i "/^# Claude profile: ${name}/d" "$ZSHRC" 2>/dev/null || true
        sed -i "/^alias claude-${name}=/d" "$ZSHRC" 2>/dev/null || true
        print_success "Removed alias from ~/.bashrc"
    fi

    echo ""
    print_info "Run 'source ~/.bashrc' to refresh aliases."
    echo ""
}

cmd_launch() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        name=$(pick_profile "launch") || exit 1
    else
        shift   # remaining args are forwarded to claude
    fi

    if [ "$name" = "default" ]; then
        exec claude "$@"
    fi

    if ! profile_exists "$name"; then
        print_error "Profile '$name' does not exist."
        print_dim "Run: claude-switch create $name"
        exit 1
    fi

    local dir
    dir="$(profile_dir "$name")"

    # If third-party API profile, pass env vars
    if [ -f "$dir/$PROVIDER_CONFIG" ]; then
        local cfg="$dir/$PROVIDER_CONFIG"
        local base_url auth_token model haiku sonnet opus subagent
        base_url=$(read_provider_field "$cfg" "base_url")
        auth_token=$(resolve_auth_token "$dir") || true
        model=$(read_provider_field "$cfg" "model")
        haiku=$(read_provider_field "$cfg" "haiku_model")
        sonnet=$(read_provider_field "$cfg" "sonnet_model")
        opus=$(read_provider_field "$cfg" "opus_model")
        subagent=$(read_provider_field "$cfg" "subagent_model")

        if [ -z "$auth_token" ]; then
            print_error "Could not retrieve the API key for '$name'."
            print_dim "Check 'auth_token_cmd' in $cfg"
            exit 1
        fi

        exec env \
            ANTHROPIC_BASE_URL="$base_url" \
            ANTHROPIC_AUTH_TOKEN="$auth_token" \
            ANTHROPIC_MODEL="$model" \
            ANTHROPIC_DEFAULT_OPUS_MODEL="$opus" \
            ANTHROPIC_DEFAULT_SONNET_MODEL="$sonnet" \
            ANTHROPIC_DEFAULT_HAIKU_MODEL="$haiku" \
            CLAUDE_CODE_SUBAGENT_MODEL="$subagent" \
            CLAUDE_CONFIG_DIR="$dir" \
            claude "$@"
    else
        exec env CLAUDE_CONFIG_DIR="$dir" claude "$@"
    fi
}

cmd_config() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        name=$(pick_profile "configure") || exit 1
    fi

    if [ "$name" = "default" ]; then
        print_error "Cannot configure the default profile as third-party."
        exit 1
    fi

    if ! profile_exists "$name"; then
        print_error "Profile '$name' does not exist."
        exit 1
    fi

    local dir
    dir="$(profile_dir "$name")"

    # Show current config if exists
    if [ -f "$dir/$PROVIDER_CONFIG" ]; then
        echo ""
        printf "  ${BOLD}Current configuration for '${CYAN}%s${RESET}${BOLD}'${RESET}\n\n" "$name"
        local cfg="$dir/$PROVIDER_CONFIG"
        printf "    ${DIM}Base URL:  %s${RESET}\n" "$(read_provider_field "$cfg" "base_url")"
        local tok_cmd
        tok_cmd=$(read_provider_field "$cfg" "auth_token_cmd")
        if [ -n "$tok_cmd" ]; then
            printf "    ${DIM}Key (via): %s${RESET}\n" "$tok_cmd"
        else
            printf "    ${DIM}API Key:   %s**** ${YELLOW}(legacy plaintext — reconfigure to secure it)${RESET}\n" \
                "$(read_provider_field "$cfg" "auth_token" | head -c 12)"
        fi
        printf "    ${DIM}Model:     %s${RESET}\n" "$(read_provider_field "$cfg" "model")"
        printf "    ${DIM}Opus:      %s${RESET}\n" "$(read_provider_field "$cfg" "opus_model")"
        printf "    ${DIM}Sonnet:    %s${RESET}\n" "$(read_provider_field "$cfg" "sonnet_model")"
        printf "    ${DIM}Haiku:     %s${RESET}\n" "$(read_provider_field "$cfg" "haiku_model")"
        printf "    ${DIM}Subagent:  %s${RESET}\n" "$(read_provider_field "$cfg" "subagent_model")"
        echo ""

        if ! ask_confirm "Reconfigure this profile?"; then
            echo ""
            print_info "Cancelled."
            return
        fi
    fi

    configure_third_party "$dir" "$name"

    # Refresh alias (delegates to claude-switch; no secret written to rc)
    if [ -f "$ZSHRC" ]; then
        sed -i "/^# Claude profile: ${name}/d" "$ZSHRC" 2>/dev/null || true
        sed -i "/^alias claude-${name}=/d" "$ZSHRC" 2>/dev/null || true

        printf "\n# Claude profile: %s\nalias claude-%s='claude-switch launch %s'\n" \
            "$name" "$name" "$name" >> "$ZSHRC"
        echo ""
        print_success "Updated alias in ~/.bashrc"
        print_info "Run 'source ~/.bashrc' to refresh."
    fi
    echo ""
}

cmd_interactive() {
    print_header

    ask_choose "What would you like to do?" \
        "Create a new profile" \
        "List all profiles" \
        "Launch a profile" \
        "Configure API for a profile" \
        "Delete a profile" \
        "Exit"

    case "$INPUT_RESULT" in
        "Create a new profile")           cmd_create ;;
        "List all profiles")              cmd_list ;;
        "Launch a profile")               cmd_launch ;;
        "Configure API for a profile")    cmd_config ;;
        "Delete a profile")               cmd_delete ;;
        "Exit"|"")                        exit 0 ;;
    esac
}

cmd_help() {
    print_header
    printf "  ${BOLD}USAGE${RESET}\n"
    printf "    claude-switch ${DIM}[command] [name]${RESET}\n"
    printf "    claude-switch ${DIM}<profile-name>${RESET}          ${DIM}# quick launch${RESET}\n\n"
    printf "  ${BOLD}COMMANDS${RESET}\n"
    printf "    ${CYAN}<name>${RESET}                Launch Claude with that profile\n"
    printf "    ${CYAN}create${RESET} ${DIM}[name]${RESET}         Create a new profile (Anthropic OAuth or third-party API)\n"
    printf "    ${CYAN}config${RESET} ${DIM}[name]${RESET}         Configure/reconfigure API for a profile\n"
    printf "    ${CYAN}list${RESET}                  List all profiles and auth status\n"
    printf "    ${CYAN}delete${RESET} ${DIM}[name]${RESET}         Delete a profile\n"
    printf "    ${CYAN}help${RESET}                  Show this help message\n"
    printf "    ${CYAN}version${RESET}               Show version\n\n"
    printf "  ${BOLD}EXAMPLES${RESET}\n"
    printf "    ${DIM}claude-switch create deepseek${RESET}    ${DIM}# create + configure DeepSeek API${RESET}\n"
    printf "    ${DIM}claude-switch deepseek${RESET}           ${DIM}# launch deepseek profile${RESET}\n"
    printf "    ${DIM}claude-switch list${RESET}               ${DIM}# show all profiles${RESET}\n"
    printf "    ${DIM}claude-switch${RESET}                    ${DIM}# interactive menu${RESET}\n\n"
    printf "  ${BOLD}HOW IT WORKS${RESET}\n"
    printf "    Each profile gets its own ~/.claude-<name>/ directory with\n"
    printf "    separate credentials and session data. Shared config\n"
    printf "    (skills, CLAUDE.md, plugins) is symlinked from ~/.claude/.\n\n"
    printf "  ${BOLD}THIRD-PARTY API${RESET}\n"
    printf "    During 'create', choose \"Third-party API\" to configure:\n"
    printf "    • Base URL, API Key, and Model names\n"
    printf "    • Per-tier models (Haiku/Sonnet/Opus) for task routing\n"
    printf "    • No OAuth login needed — works immediately\n"
    echo ""
}

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
    if ! command -v claude >/dev/null 2>&1; then
        print_error "Claude Code not found in PATH."
        print_dim "Install it first: https://docs.anthropic.com/en/docs/claude-code"
        exit 1
    fi

    case "${1:-}" in
        create)              shift; cmd_create "$@" ;;
        config|configure)    shift; cmd_config "$@" ;;
        list|ls)             shift; cmd_list "$@" ;;
        delete|rm|remove)    shift; cmd_delete "$@" ;;
        launch|run|start)    shift; cmd_launch "$@" ;;
        help|-h|--help)      cmd_help ;;
        version|-v|--version) echo "claude-switch v$VERSION" ;;
        "")                  cmd_interactive ;;
        *)
            # If arg matches a profile name, launch it directly
            if profile_exists "$1"; then
                cmd_launch "$@"
            else
                print_error "Unknown command or profile: $1"
                echo ""
                cmd_help
                exit 1
            fi
            ;;
    esac
}

main "$@"
