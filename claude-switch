#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# claude-switch — Run multiple Claude Code accounts on one machine
#                 Now with third-party API provider support!
# ─────────────────────────────────────────────────────────────────────────────

VERSION="2.1.0"
CLAUDE_HOME="$HOME/.claude"
PROFILE_PREFIX="$HOME/.claude-"
PROFILE_MARKER=".profile-name"
PROVIDER_CONFIG=".provider.json"
ZSHRC="$HOME/.bashrc"
SHARED_ITEMS="skills CLAUDE.md plugins projects"

# Antigravity (agy) defaults — Claude via a local Antigravity→Anthropic proxy
AGY_DEFAULT_PORT="8080"
AGY_PROXY_CMD_DEFAULT="npx -y antigravity-claude-proxy@latest start"
AGY_OPUS="claude-opus-4-6-thinking"
AGY_SONNET="claude-sonnet-4-6"

# ── Colors & Icons ───────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

IC_CHECK="\xe2\x9c\x94"   # ✔
IC_CROSS="\xe2\x9c\x98"   # ✘
IC_ARROW="\xe2\x96\xb6"   # ▶
IC_PERSON="\xe2\x97\x89"  # ◉
IC_LINK="\xe2\x86\x92"    # →
IC_API="\xe2\x97\x86"     # ◆

# ── Gum helpers ──────────────────────────────────────────────────────────────

ensure_gum() {
    if command -v gum >/dev/null 2>&1; then
        return 0
    fi
    echo ""
    printf "  ${YELLOW}gum${RESET} is required for interactive menus.\n"
    echo ""
    if command -v brew >/dev/null 2>&1; then
        printf "  Installing via Homebrew...\n"
        brew install gum
    else
        printf "  Install it: ${CYAN}brew install gum${RESET}  or  ${CYAN}go install github.com/charmbracelet/gum@latest${RESET}\n"
        exit 1
    fi
}

ensure_python3() {
    if command -v python3 >/dev/null 2>&1; then
        return 0
    fi
    print_error "python3 not found in PATH."
    print_dim "Required to read/write profile provider config. Install python3 and re-run."
    exit 1
}

# ── Utility Functions ────────────────────────────────────────────────────────

print_header() {
    echo ""
    gum style \
        --border double \
        --border-foreground 208 \
        --padding "1 3" \
        --margin "0 2" \
        --align center \
        "$(gum style --bold --foreground 208 'C L A U D E   S W I T C H')" \
        "" \
        "$(gum style --faint "v${VERSION}  ·  multi-account + third-party API support")"
    echo ""
}

print_success() { printf "  ${GREEN}${IC_CHECK}${RESET}  %s\n" "$1"; }
print_error()   { printf "  ${RED}${IC_CROSS}${RESET}  %s\n" "$1"; }
print_warn()    { printf "  ${YELLOW}!${RESET}  %s\n" "$1"; }
print_info()    { printf "  ${BLUE}${IC_ARROW}${RESET}  %s\n" "$1"; }
print_dim()     { printf "  ${DIM}   %s${RESET}\n" "$1"; }

validate_profile_name() {
    local name="$1"
    if [ -z "$name" ]; then
        print_error "Profile name cannot be empty."
        return 1
    fi
    if [ "$name" = "default" ]; then
        print_error "'default' is reserved for the primary ~/.claude/ profile."
        return 1
    fi
    if ! printf '%s' "$name" | grep -qE '^[a-zA-Z][a-zA-Z0-9_-]*$'; then
        print_error "Invalid name. Use letters, numbers, hyphens, underscores. Must start with a letter."
        return 1
    fi
    if [ ${#name} -gt 32 ]; then
        print_error "Profile name must be 32 characters or fewer."
        return 1
    fi
    return 0
}

profile_dir() { echo "${PROFILE_PREFIX}$1"; }

profile_exists() {
    local dir
    dir="$(profile_dir "$1")"
    [ -d "$dir" ] && [ -f "$dir/$PROFILE_MARKER" ]
}

is_api_profile() {
    local dir
    dir="$(profile_dir "$1")"
    [ -f "$dir/$PROVIDER_CONFIG" ]
}

get_all_profiles() {
    for dir in "${PROFILE_PREFIX}"*/; do
        [ -d "$dir" ] || continue
        [ -f "$dir/$PROFILE_MARKER" ] || continue
        local name
        name="$(basename "$dir")"
        name="${name#.claude-}"
        echo "$name"
    done
}

check_auth_status() {
    local config_dir="$1"
    local output
    if [ "$config_dir" = "$CLAUDE_HOME" ]; then
        output=$(claude auth status 2>&1) || true
    else
        output=$(CLAUDE_CONFIG_DIR="$config_dir" claude auth status 2>&1) || true
    fi
    local email
    email=$(printf '%s' "$output" | grep -o '"email"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"email"[[:space:]]*:[[:space:]]*"//;s/"//')
    if [ -n "$email" ]; then
        echo "$email"
    elif printf '%s' "$output" | grep -q '"loggedIn": true'; then
        echo "logged in"
    else
        echo ""
    fi
}

pick_profile() {
    local action="$1"
    local profiles
    profiles=$(get_all_profiles)
    if [ -z "$profiles" ]; then
        print_warn "No profiles found. Create one first."
        return 1
    fi
    local choice
    choice=$(echo "$profiles" | gum choose --header "Select a profile to ${action}:" --cursor.foreground 208 --header.foreground 252)
    if [ -z "$choice" ]; then
        return 1
    fi
    echo "$choice"
}

# ── Provider config helpers ──────────────────────────────────────────────────

read_provider_field() {
    local file="$1" field="$2"
    if [ -f "$file" ]; then
        # Values passed via env (not string-interpolated) to avoid quote injection.
        CS_FILE="$file" CS_FIELD="$field" python3 -c "
import json, os
with open(os.environ['CS_FILE']) as f:
    data = json.load(f)
print(data.get(os.environ['CS_FIELD'], ''))
" 2>/dev/null || echo ""
    else
        echo ""
    fi
}

write_provider_config() {
    local dir="$1" base_url="$2" auth_token="$3" model="$4"
    local haiku="${5:-$model}" sonnet="${6:-$model}" opus="${7:-$model}" subagent="${8:-$model}"
    local provider="${9:-custom}" proxy_command="${10:-}"
    # Values passed via env (not string-interpolated) to avoid quote injection.
    CS_FILE="$dir/$PROVIDER_CONFIG" \
    CS_BASE_URL="$base_url" CS_AUTH="$auth_token" CS_MODEL="$model" \
    CS_HAIKU="$haiku" CS_SONNET="$sonnet" CS_OPUS="$opus" CS_SUBAGENT="$subagent" \
    CS_PROVIDER="$provider" CS_PROXY="$proxy_command" \
    python3 -c "
import json, os
data = {
    'base_url': os.environ['CS_BASE_URL'],
    'auth_token': os.environ['CS_AUTH'],
    'model': os.environ['CS_MODEL'],
    'haiku_model': os.environ['CS_HAIKU'],
    'sonnet_model': os.environ['CS_SONNET'],
    'opus_model': os.environ['CS_OPUS'],
    'subagent_model': os.environ['CS_SUBAGENT'],
    'provider': os.environ['CS_PROVIDER'],
    'proxy_command': os.environ['CS_PROXY'],
}
with open(os.environ['CS_FILE'], 'w') as f:
    json.dump(data, f, indent=2)
"
}

build_env_prefix() {
    local dir="$1"
    local cfg="$dir/$PROVIDER_CONFIG"
    local base_url auth_token model haiku sonnet opus subagent
    base_url=$(read_provider_field "$cfg" "base_url")
    auth_token=$(read_provider_field "$cfg" "auth_token")
    model=$(read_provider_field "$cfg" "model")
    haiku=$(read_provider_field "$cfg" "haiku_model")
    sonnet=$(read_provider_field "$cfg" "sonnet_model")
    opus=$(read_provider_field "$cfg" "opus_model")
    subagent=$(read_provider_field "$cfg" "subagent_model")

    printf 'ANTHROPIC_BASE_URL="%s" \\\n    ANTHROPIC_AUTH_TOKEN="%s" \\\n    ANTHROPIC_MODEL="%s" \\\n    ANTHROPIC_DEFAULT_OPUS_MODEL="%s" \\\n    ANTHROPIC_DEFAULT_SONNET_MODEL="%s" \\\n    ANTHROPIC_DEFAULT_HAIKU_MODEL="%s" \\\n    CLAUDE_CODE_SUBAGENT_MODEL="%s" \\\n    ' \
        "$base_url" "$auth_token" "$model" "$opus" "$sonnet" "$haiku" "$subagent"
}

# ── Antigravity proxy helpers ────────────────────────────────────────────────

# Parse "http://host:port/path" into "host port" (defaults: localhost / 80).
proxy_host_port() {
    local url="$1" hostport host port
    hostport="${url#*://}"      # strip scheme
    hostport="${hostport%%/*}"  # strip path
    host="${hostport%%:*}"
    port="${hostport##*:}"
    [ "$port" = "$hostport" ] && port="80"   # no colon → default port
    [ -z "$host" ] && host="localhost"
    [ -z "$port" ] && port="80"
    echo "$host $port"
}

# Returns 0 if something is listening on the proxy's host:port.
proxy_is_up() {
    local url="$1" hp host port
    hp="$(proxy_host_port "$url")"
    host="${hp%% *}"; port="${hp##* }"
    (exec 3<>"/dev/tcp/$host/$port") 2>/dev/null && return 0 || return 1
}

# For Antigravity profiles: ensure the proxy is reachable, auto-starting it if
# a proxy_command is configured. Returns non-zero if it cannot be made ready.
ensure_proxy_running() {
    local cfg="$1" dir base_url proxy_cmd
    dir="${cfg%/*}"
    base_url=$(read_provider_field "$cfg" "base_url")
    proxy_cmd=$(read_provider_field "$cfg" "proxy_command")

    if proxy_is_up "$base_url"; then
        return 0
    fi

    print_warn "Antigravity proxy not reachable at $base_url"
    if [ -z "$proxy_cmd" ]; then
        print_dim "Start your proxy and retry, e.g.:  $AGY_PROXY_CMD_DEFAULT"
        return 1
    fi

    local logf="$dir/proxy.log"
    print_info "Starting proxy: $proxy_cmd"
    print_dim "Logs: $logf"
    nohup bash -c "$proxy_cmd" >"$logf" 2>&1 &
    echo "$!" > "$dir/proxy.pid"

    local i
    for i in $(seq 1 30); do
        if proxy_is_up "$base_url"; then
            print_success "Proxy is up (pid $(cat "$dir/proxy.pid"))"
            return 0
        fi
        sleep 1
    done
    print_error "Proxy did not come up within 30s. Check $logf"
    return 1
}

# ── Commands ─────────────────────────────────────────────────────────────────

configure_third_party() {
    local dir="$1" name="$2"

    echo ""
    gum style \
        --border rounded \
        --border-foreground 99 \
        --padding "1 2" \
        --margin "0 2" \
        "$(gum style --bold --foreground 99 '🔌 Third-Party API Configuration')" \
        "" \
        "$(gum style --faint 'Configure your API provider (DeepSeek, Volcano Engine, OpenRouter, etc.)')"
    echo ""

    # Base URL
    local base_url
    base_url=$(gum input \
        --placeholder "e.g. https://api.deepseek.com/anthropic" \
        --header "API Base URL" \
        --width 70 \
        --cursor.foreground 99 \
        --header.foreground 252)
    if [ -z "$base_url" ]; then
        print_error "Base URL is required."
        return 1
    fi

    # API Key
    local auth_token
    auth_token=$(gum input \
        --placeholder "e.g. sk-xxxx or ark-xxxx" \
        --header "API Key / Auth Token" \
        --width 70 \
        --password \
        --cursor.foreground 99 \
        --header.foreground 252)
    if [ -z "$auth_token" ]; then
        print_error "API key is required."
        return 1
    fi

    # Primary model
    local model
    model=$(gum input \
        --placeholder "e.g. deepseek-v4-pro, glm-5.1, ark-code-latest" \
        --header "Primary Model Name" \
        --width 70 \
        --cursor.foreground 99 \
        --header.foreground 252)
    if [ -z "$model" ]; then
        print_error "Model name is required."
        return 1
    fi

    # Ask about per-tier models
    local haiku="$model" sonnet="$model" opus="$model" subagent="$model"

    echo ""
    if gum confirm "Use different models for different tiers (Haiku/Sonnet/Opus)?" --affirmative "Yes, customize" --negative "No, use '$model' for all" --default=false; then
        echo ""
        opus=$(gum input \
            --placeholder "$model" \
            --value "$model" \
            --header "Opus model (complex tasks)" \
            --width 70 \
            --cursor.foreground 99 \
            --header.foreground 252)
        [ -z "$opus" ] && opus="$model"

        sonnet=$(gum input \
            --placeholder "$model" \
            --value "$model" \
            --header "Sonnet model (balanced tasks)" \
            --width 70 \
            --cursor.foreground 99 \
            --header.foreground 252)
        [ -z "$sonnet" ] && sonnet="$model"

        haiku=$(gum input \
            --placeholder "$model" \
            --value "$model" \
            --header "Haiku model (fast/light tasks)" \
            --width 70 \
            --cursor.foreground 99 \
            --header.foreground 252)
        [ -z "$haiku" ] && haiku="$model"

        subagent=$(gum input \
            --placeholder "$haiku" \
            --value "$haiku" \
            --header "Subagent model" \
            --width 70 \
            --cursor.foreground 99 \
            --header.foreground 252)
        [ -z "$subagent" ] && subagent="$haiku"
    fi

    # Save provider config
    write_provider_config "$dir" "$base_url" "$auth_token" "$model" "$haiku" "$sonnet" "$opus" "$subagent"

    # Create settings.json with model (don't symlink from shared)
    rm -f "$dir/settings.json" 2>/dev/null || true
    printf '{\n  "theme": "dark",\n  "model": "%s"\n}\n' "$model" > "$dir/settings.json"

    # Set hasCompletedOnboarding
    printf '{\n  "hasCompletedOnboarding": true\n}\n' > "$dir/.claude.json"

    echo ""
    printf "    ${DIM}${IC_API} Base URL:  %s${RESET}\n" "$base_url"
    printf "    ${DIM}${IC_API} API Key:   %s****${RESET}\n" "$(echo "$auth_token" | head -c 12)"
    printf "    ${DIM}${IC_API} Model:     %s${RESET}\n" "$model"
    if [ "$haiku" != "$model" ] || [ "$sonnet" != "$model" ] || [ "$opus" != "$model" ]; then
        printf "    ${DIM}${IC_API} Opus:      %s${RESET}\n" "$opus"
        printf "    ${DIM}${IC_API} Sonnet:    %s${RESET}\n" "$sonnet"
        printf "    ${DIM}${IC_API} Haiku:     %s${RESET}\n" "$haiku"
        printf "    ${DIM}${IC_API} Subagent:  %s${RESET}\n" "$subagent"
    fi
    echo ""
    print_success "Third-party API configured"
}

configure_antigravity() {
    local dir="$1" name="$2"

    echo ""
    gum style \
        --border rounded \
        --border-foreground 213 \
        --padding "1 2" \
        --margin "0 2" \
        "$(gum style --bold --foreground 213 '🪐 Antigravity (agy) — Claude via Google Antigravity')" \
        "" \
        "$(gum style --faint 'Routes Claude Code through a local proxy backed by your Google Antigravity subscription.')"
    echo ""

    print_warn "Using Antigravity as an API backend may violate Google's Terms of Service."
    print_dim  "Some users have reported account bans/shadow-bans. Use your own account at your own risk."
    echo ""

    # Proxy base URL (the proxy must be running locally)
    local base_url
    base_url=$(gum input \
        --placeholder "http://localhost:${AGY_DEFAULT_PORT}" \
        --value "http://localhost:${AGY_DEFAULT_PORT}" \
        --header "Proxy Base URL" \
        --width 70 \
        --cursor.foreground 213 \
        --header.foreground 252)
    [ -z "$base_url" ] && base_url="http://localhost:${AGY_DEFAULT_PORT}"

    # Models (preset to Antigravity's Claude names, overridable)
    local opus sonnet
    opus=$(gum input \
        --placeholder "$AGY_OPUS" --value "$AGY_OPUS" \
        --header "Opus model (complex tasks)" \
        --width 70 --cursor.foreground 213 --header.foreground 252)
    [ -z "$opus" ] && opus="$AGY_OPUS"

    sonnet=$(gum input \
        --placeholder "$AGY_SONNET" --value "$AGY_SONNET" \
        --header "Sonnet/Haiku model (everything else)" \
        --width 70 --cursor.foreground 213 --header.foreground 252)
    [ -z "$sonnet" ] && sonnet="$AGY_SONNET"

    # Optional auto-start of the proxy on launch
    local proxy_cmd=""
    echo ""
    if gum confirm "Auto-start the proxy when launching this profile?" --affirmative "Yes" --negative "No, I'll start it myself" --default=true; then
        proxy_cmd=$(gum input \
            --placeholder "$AGY_PROXY_CMD_DEFAULT" --value "$AGY_PROXY_CMD_DEFAULT" \
            --header "Command to start the proxy" \
            --width 70 --cursor.foreground 213 --header.foreground 252)
        [ -z "$proxy_cmd" ] && proxy_cmd="$AGY_PROXY_CMD_DEFAULT"
    fi

    # The proxy authenticates to Google via OAuth; Claude Code's token is a dummy.
    local token="test"

    # write_provider_config args: dir base_url token model haiku sonnet opus subagent provider proxy_cmd
    write_provider_config "$dir" "$base_url" "$token" "$opus" "$sonnet" "$sonnet" "$opus" "$sonnet" "antigravity" "$proxy_cmd"

    rm -f "$dir/settings.json" 2>/dev/null || true
    printf '{\n  "theme": "dark",\n  "model": "%s"\n}\n' "$opus" > "$dir/settings.json"
    printf '{\n  "hasCompletedOnboarding": true\n}\n' > "$dir/.claude.json"

    echo ""
    printf "    ${DIM}${IC_API} Proxy URL:  %s${RESET}\n" "$base_url"
    printf "    ${DIM}${IC_API} Opus:       %s${RESET}\n" "$opus"
    printf "    ${DIM}${IC_API} Sonnet:     %s${RESET}\n" "$sonnet"
    if [ -n "$proxy_cmd" ]; then
        printf "    ${DIM}${IC_API} Auto-start: %s${RESET}\n" "$proxy_cmd"
    else
        printf "    ${DIM}${IC_API} Auto-start: off (start the proxy yourself)${RESET}\n"
    fi
    echo ""
    print_success "Antigravity profile configured"
}

cmd_create() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        name=$(gum input --placeholder "Profile name (e.g. work, deepseek, hs)" --header "Create a new profile" --cursor.foreground 208 --header.foreground 252)
    fi

    if [ -z "$name" ]; then
        print_info "Cancelled."
        exit 0
    fi

    if ! validate_profile_name "$name"; then
        exit 1
    fi

    local dir
    dir="$(profile_dir "$name")"

    if [ -d "$dir" ] && [ -f "$dir/$PROFILE_MARKER" ]; then
        print_error "Profile '$name' already exists at $dir"
        exit 1
    fi

    if [ -d "$dir" ] && [ ! -f "$dir/$PROFILE_MARKER" ]; then
        print_error "Directory $dir exists but is not a profile."
        print_dim "Inspect it manually or choose a different name."
        exit 1
    fi

    # Ask about profile type
    echo ""
    local profile_type
    profile_type=$(gum choose \
        "Anthropic (OAuth login)" \
        "Antigravity (agy) — Claude Opus via Google Antigravity" \
        "Third-party API (DeepSeek, Volcano Engine, OpenRouter, etc.)" \
        --header "What type of profile?" \
        --cursor.foreground 208 \
        --header.foreground 252 \
        --cursor "▶ " \
        --selected.foreground 208)

    if [ -z "$profile_type" ]; then
        print_info "Cancelled."
        exit 0
    fi

    local is_third_party=false is_antigravity=false
    case "$profile_type" in
        "Antigravity"*) is_third_party=true; is_antigravity=true ;;
        "Third-party"*) is_third_party=true ;;
    esac

    # Create profile
    printf "\n  ${BOLD}Creating profile '${CYAN}%s${RESET}${BOLD}'${RESET}\n\n" "$name"

    mkdir -p "$dir"
    echo "$name" > "$dir/$PROFILE_MARKER"

    # Symlink shared items (skip settings.json for third-party — they get their own)
    local items_to_link="$SHARED_ITEMS"
    if [ "$is_third_party" = false ]; then
        items_to_link="$SHARED_ITEMS settings.json"
    fi

    for item in $items_to_link; do
        if [ -e "$CLAUDE_HOME/$item" ]; then
            ln -sf "$CLAUDE_HOME/$item" "$dir/$item"
            printf "    ${DIM}${IC_LINK} %s${RESET}\n" "$item"
        else
            printf "    ${DIM}~ %s (not found, will link when created)${RESET}\n" "$item"
        fi
    done

    echo ""
    print_success "Profile created at ~/.claude-$name/"

    # Configure provider if selected
    if [ "$is_antigravity" = true ]; then
        configure_antigravity "$dir" "$name"
    elif [ "$is_third_party" = true ]; then
        configure_third_party "$dir" "$name"
    fi

    echo ""

    # Add alias to shell rc
    if [ ! -f "$ZSHRC" ]; then
        touch "$ZSHRC"
    fi

    if grep -q "alias claude-${name}=" "$ZSHRC" 2>/dev/null; then
        # Remove old alias to replace it
        sed -i "/^# Claude profile: ${name}$/d" "$ZSHRC" 2>/dev/null || true
        sed -i "/^alias claude-${name}=/d" "$ZSHRC" 2>/dev/null || true
    fi

    if [ "$is_antigravity" = true ]; then
        # Route through claude-switch so the proxy is health-checked / auto-started.
        printf '\n# Claude profile: %s (antigravity)\nalias claude-%s='\''claude-switch %s'\''\n' \
            "$name" "$name" "$name" >> "$ZSHRC"
    elif [ "$is_third_party" = true ]; then
        local env_prefix
        env_prefix=$(build_env_prefix "$dir")
        printf '\n# Claude profile: %s (third-party API)\nalias claude-%s='\''%sCLAUDE_CONFIG_DIR="%s" claude'\''\n' \
            "$name" "$name" "$env_prefix" "$dir" >> "$ZSHRC"
    else
        printf '\n# Claude profile: %s\nalias claude-%s='\''CLAUDE_CONFIG_DIR="%s" claude'\''\n' \
            "$name" "$name" "$dir" >> "$ZSHRC"
    fi
    printf "  ${GREEN}${IC_CHECK}${RESET}  Added alias ${BOLD}claude-${name}${RESET} to ~/.bashrc\n"

    echo ""

    if [ "$is_antigravity" = true ]; then
        gum style \
            --border rounded \
            --border-foreground 240 \
            --padding "1 2" \
            --margin "0 2" \
            "$(gum style --bold 'Quick start')" \
            "" \
            "  source ~/.bashrc" \
            "  $(gum style --foreground 213 "claude-$name")" \
            "" \
            "$(gum style --faint 'Launching health-checks the proxy and starts it if needed.')" \
            "$(gum style --faint 'Make sure your Antigravity (agy) account is logged in.')"
    elif [ "$is_third_party" = true ]; then
        gum style \
            --border rounded \
            --border-foreground 240 \
            --padding "1 2" \
            --margin "0 2" \
            "$(gum style --bold 'Quick start')" \
            "" \
            "  source ~/.bashrc" \
            "  $(gum style --foreground 99 "claude-$name")" \
            "" \
            "$(gum style --faint 'Third-party API configured — no OAuth login needed.')"
    else
        gum style \
            --border rounded \
            --border-foreground 240 \
            --padding "1 2" \
            --margin "0 2" \
            "$(gum style --bold 'Quick start')" \
            "" \
            "  source ~/.bashrc" \
            "  $(gum style --foreground 99 "claude-switch $name")" \
            "" \
            "$(gum style --faint 'Claude will prompt you to log in on first launch.')"
    fi

    echo ""
}

cmd_list() {
    echo ""
    printf "  ${BOLD}Profiles${RESET}\n\n"

    # Default profile
    local default_status
    default_status=$(check_auth_status "$CLAUDE_HOME")

    if [ -n "$default_status" ]; then
        printf "  ${IC_PERSON}  ${BOLD}%-16s${RESET} ${DIM}%-24s${RESET} ${GREEN}${IC_CHECK} %s${RESET}\n" \
            "default" "~/.claude/" "$default_status"
    else
        printf "  ${IC_PERSON}  ${BOLD}%-16s${RESET} ${DIM}%-24s${RESET} ${RED}${IC_CROSS} not logged in${RESET}\n" \
            "default" "~/.claude/"
    fi

    # Additional profiles
    local profiles
    profiles=$(get_all_profiles)
    if [ -n "$profiles" ]; then
        while IFS= read -r name; do
            local dir status provider_label=""
            dir="$(profile_dir "$name")"

            # Check if third-party API profile
            if [ -f "$dir/$PROVIDER_CONFIG" ]; then
                local api_model provider_kind
                api_model=$(read_provider_field "$dir/$PROVIDER_CONFIG" "model")
                provider_kind=$(read_provider_field "$dir/$PROVIDER_CONFIG" "provider")
                if [ "$provider_kind" = "antigravity" ]; then
                    local up
                    if proxy_is_up "$(read_provider_field "$dir/$PROVIDER_CONFIG" "base_url")"; then
                        up="${GREEN}● proxy up${RESET}"
                    else
                        up="${RED}○ proxy down${RESET}"
                    fi
                    printf "  🪐  ${BOLD}%-16s${RESET} ${DIM}%-24s${RESET} ${MAGENTA}agy: %s${RESET}  %b\n" \
                        "$name" "~/.claude-$name/" "$api_model" "$up"
                else
                    provider_label="API: $api_model"
                    printf "  ${IC_API}  ${BOLD}%-16s${RESET} ${DIM}%-24s${RESET} ${MAGENTA}${IC_CHECK} %s${RESET}\n" \
                        "$name" "~/.claude-$name/" "$provider_label"
                fi
            else
                status=$(check_auth_status "$dir")
                if [ -n "$status" ]; then
                    printf "  ${IC_PERSON}  ${BOLD}%-16s${RESET} ${DIM}%-24s${RESET} ${GREEN}${IC_CHECK} %s${RESET}\n" \
                        "$name" "~/.claude-$name/" "$status"
                else
                    printf "  ${IC_PERSON}  ${BOLD}%-16s${RESET} ${DIM}%-24s${RESET} ${RED}${IC_CROSS} not logged in${RESET}\n" \
                        "$name" "~/.claude-$name/"
                fi
            fi
        done <<< "$profiles"
    fi

    echo ""

    local count=1
    if [ -n "$profiles" ]; then
        local profile_count
        profile_count=$(printf '%s\n' "$profiles" | wc -l | tr -d ' ')
        count=$((profile_count + 1))
    fi
    printf "  ${DIM}%d profile(s) total${RESET}\n\n" "$count"
}

cmd_delete() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        name=$(pick_profile "delete") || exit 1
    fi

    if [ "$name" = "default" ]; then
        print_error "Cannot delete the default profile."
        exit 1
    fi

    if ! profile_exists "$name"; then
        print_error "Profile '$name' does not exist."
        exit 1
    fi

    local dir
    dir="$(profile_dir "$name")"

    echo ""
    gum style \
        --border rounded \
        --border-foreground 196 \
        --padding "1 2" \
        --margin "0 2" \
        "$(gum style --bold --foreground 196 "Delete profile '${name}'")" \
        "" \
        "This will permanently remove:" \
        "  - Profile directory: ~/.claude-${name}/" \
        "  - Alias 'claude-${name}' from ~/.bashrc" \
        "  - Sessions, history, and cached data" \
        "" \
        "$(gum style --faint 'OAuth tokens in macOS Keychain may persist.')"

    echo ""

    if ! gum confirm "Delete profile '${name}'?" --affirmative "Yes, delete" --negative "Cancel" --default=false; then
        echo ""
        print_info "Cancelled."
        echo ""
        return
    fi

    echo ""

    rm -rf "$dir"
    print_success "Removed ~/.claude-$name/"

    if [ -f "$ZSHRC" ]; then
        sed -i "/^# Claude profile: ${name}/d" "$ZSHRC" 2>/dev/null || true
        sed -i "/^alias claude-${name}=/d" "$ZSHRC" 2>/dev/null || true
        print_success "Removed alias from ~/.bashrc"
    fi

    echo ""
    print_info "Run 'source ~/.bashrc' to refresh aliases."
    echo ""
}

cmd_launch() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        name=$(pick_profile "launch") || exit 1
    fi

    if [ "$name" = "default" ]; then
        exec claude
    fi

    if ! profile_exists "$name"; then
        print_error "Profile '$name' does not exist."
        print_dim "Run: claude-switch create $name"
        exit 1
    fi

    local dir
    dir="$(profile_dir "$name")"

    # If third-party API profile, pass env vars
    if [ -f "$dir/$PROVIDER_CONFIG" ]; then
        local cfg="$dir/$PROVIDER_CONFIG"

        # Antigravity profiles need their local proxy reachable first.
        if [ "$(read_provider_field "$cfg" "provider")" = "antigravity" ]; then
            ensure_proxy_running "$cfg" || {
                print_error "Antigravity proxy unavailable — aborting launch."
                exit 1
            }
        fi

        local base_url auth_token model haiku sonnet opus subagent
        base_url=$(read_provider_field "$cfg" "base_url")
        auth_token=$(read_provider_field "$cfg" "auth_token")
        model=$(read_provider_field "$cfg" "model")
        haiku=$(read_provider_field "$cfg" "haiku_model")
        sonnet=$(read_provider_field "$cfg" "sonnet_model")
        opus=$(read_provider_field "$cfg" "opus_model")
        subagent=$(read_provider_field "$cfg" "subagent_model")

        exec env \
            ANTHROPIC_BASE_URL="$base_url" \
            ANTHROPIC_AUTH_TOKEN="$auth_token" \
            ANTHROPIC_MODEL="$model" \
            ANTHROPIC_DEFAULT_OPUS_MODEL="$opus" \
            ANTHROPIC_DEFAULT_SONNET_MODEL="$sonnet" \
            ANTHROPIC_DEFAULT_HAIKU_MODEL="$haiku" \
            CLAUDE_CODE_SUBAGENT_MODEL="$subagent" \
            CLAUDE_CONFIG_DIR="$dir" \
            claude
    else
        exec env CLAUDE_CONFIG_DIR="$dir" claude
    fi
}

cmd_config() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        name=$(pick_profile "configure") || exit 1
    fi

    if [ "$name" = "default" ]; then
        print_error "Cannot configure the default profile as third-party."
        exit 1
    fi

    if ! profile_exists "$name"; then
        print_error "Profile '$name' does not exist."
        exit 1
    fi

    local dir
    dir="$(profile_dir "$name")"

    # Show current config if exists
    if [ -f "$dir/$PROVIDER_CONFIG" ]; then
        echo ""
        printf "  ${BOLD}Current configuration for '${CYAN}%s${RESET}${BOLD}'${RESET}\n\n" "$name"
        local cfg="$dir/$PROVIDER_CONFIG"
        printf "    ${DIM}Base URL:  %s${RESET}\n" "$(read_provider_field "$cfg" "base_url")"
        local token
        token=$(read_provider_field "$cfg" "auth_token")
        printf "    ${DIM}API Key:   %s****${RESET}\n" "$(echo "$token" | head -c 12)"
        printf "    ${DIM}Model:     %s${RESET}\n" "$(read_provider_field "$cfg" "model")"
        printf "    ${DIM}Opus:      %s${RESET}\n" "$(read_provider_field "$cfg" "opus_model")"
        printf "    ${DIM}Sonnet:    %s${RESET}\n" "$(read_provider_field "$cfg" "sonnet_model")"
        printf "    ${DIM}Haiku:     %s${RESET}\n" "$(read_provider_field "$cfg" "haiku_model")"
        printf "    ${DIM}Subagent:  %s${RESET}\n" "$(read_provider_field "$cfg" "subagent_model")"
        echo ""

        if ! gum confirm "Reconfigure this profile?" --affirmative "Yes" --negative "Cancel" --default=false; then
            echo ""
            print_info "Cancelled."
            return
        fi
    fi

    # Keep Antigravity profiles as Antigravity when reconfiguring.
    local was_antigravity=false
    [ "$(read_provider_field "$dir/$PROVIDER_CONFIG" "provider")" = "antigravity" ] && was_antigravity=true

    if [ "$was_antigravity" = true ]; then
        configure_antigravity "$dir" "$name"
    else
        configure_third_party "$dir" "$name"
    fi

    # Update alias in shell rc
    if [ -f "$ZSHRC" ]; then
        sed -i "/^# Claude profile: ${name}/d" "$ZSHRC" 2>/dev/null || true
        sed -i "/^alias claude-${name}=/d" "$ZSHRC" 2>/dev/null || true

        if [ "$was_antigravity" = true ]; then
            printf '\n# Claude profile: %s (antigravity)\nalias claude-%s='\''claude-switch %s'\''\n' \
                "$name" "$name" "$name" >> "$ZSHRC"
        else
            local env_prefix
            env_prefix=$(build_env_prefix "$dir")
            printf '\n# Claude profile: %s (third-party API)\nalias claude-%s='\''%sCLAUDE_CONFIG_DIR="%s" claude'\''\n' \
                "$name" "$name" "$env_prefix" "$dir" >> "$ZSHRC"
        fi
        echo ""
        print_success "Updated alias in ~/.bashrc"
        print_info "Run 'source ~/.bashrc' to refresh."
    fi
    echo ""
}

cmd_proxy() {
    local name="${1:-}" action="${2:-status}"
    if [ -z "$name" ]; then
        name=$(pick_profile "manage the proxy for") || exit 1
    fi

    if ! profile_exists "$name"; then
        print_error "Profile '$name' does not exist."
        exit 1
    fi

    local dir cfg
    dir="$(profile_dir "$name")"
    cfg="$dir/$PROVIDER_CONFIG"

    if [ "$(read_provider_field "$cfg" "provider")" != "antigravity" ]; then
        print_error "'$name' is not an Antigravity profile."
        exit 1
    fi

    local base_url pidfile
    base_url=$(read_provider_field "$cfg" "base_url")
    pidfile="$dir/proxy.pid"

    echo ""
    case "$action" in
        status)
            if proxy_is_up "$base_url"; then
                print_success "Proxy is up at $base_url"
            else
                print_warn "Proxy is down ($base_url)"
            fi
            ;;
        start)
            ensure_proxy_running "$cfg"
            ;;
        stop)
            if [ -f "$pidfile" ]; then
                local pid; pid="$(cat "$pidfile")"
                if kill "$pid" 2>/dev/null; then
                    print_success "Stopped proxy (pid $pid)"
                else
                    print_warn "No running process for pid $pid (already stopped)."
                fi
                rm -f "$pidfile"
            else
                print_warn "No pid file — proxy was not started by claude-switch."
                print_dim "Stop it wherever you launched it."
            fi
            ;;
        *)
            print_error "Unknown action '$action'. Use: start | stop | status"
            exit 1
            ;;
    esac
    echo ""
}

cmd_interactive() {
    print_header

    local choice
    choice=$(gum choose \
        "Create a new profile" \
        "List all profiles" \
        "Launch a profile" \
        "Configure API for a profile" \
        "Manage Antigravity proxy" \
        "Delete a profile" \
        "Exit" \
        --header "What would you like to do?" \
        --cursor.foreground 208 \
        --header.foreground 252 \
        --cursor "▶ " \
        --selected.foreground 208)

    case "$choice" in
        "Create a new profile")           cmd_create ;;
        "List all profiles")              cmd_list ;;
        "Launch a profile")               cmd_launch ;;
        "Configure API for a profile")    cmd_config ;;
        "Manage Antigravity proxy")       cmd_proxy ;;
        "Delete a profile")               cmd_delete ;;
        "Exit"|"")                        exit 0 ;;
    esac
}

